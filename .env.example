# Where the authenticated dashboard is hosted (Fly.io app).
# Used to redirect /login, /logout, /dashboard CTAs.
NEXT_PUBLIC_DASHBOARD_URL=https://app.cruxlogic.ai

# Apex URL of this marketing site (used for social/OG preview images).
NEXT_PUBLIC_SITE_URL=https://cruxlogic.ai

# ── Waitlist (required for the waitlist to store + email) ──────────────
# Supabase — stores waitlist signups (and powers /blog + /api/feedback).
# Use the SAME project as the dashboard. Run supabase/waitlist.sql once.
NEXT_PUBLIC_SUPABASE_URL=https://kmycsuojnaxnzhljslmt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — emails you when someone joins the waitlist.
RESEND_API_KEY=re_your_api_key
# From address must be on a domain you've verified in Resend.
# For quick testing you can use: CruxLogic Waitlist <onboarding@resend.dev>
WAITLIST_FROM_EMAIL=CruxLogic Waitlist <waitlist@cruxlogic.ai>
# Where waitlist notifications are sent.
WAITLIST_NOTIFY_EMAIL=hello@cruxlogic.ai
